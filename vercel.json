{
  "buildCommand": "npm run build --prefix studycompfor_gate",
  "outputDirectory": "studycompfor_gate/build",
  "env": {
    "REACT_APP_API_URL": "@react_app_api_url",
    "NODE_ENV": "production"
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://scfg-backend.vercel.app/api/:path*"
    }
  ]
}